# Environment variables for Railway / Render / Fly.io
# Copy this to .env and fill in values

# ─── Database (Neon, Supabase, Railway PostgreSQL) ──────────────────
DATABASE_URL="postgresql://user:password@host:5432/legion_terminal?sslmode=require"

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET="generate-a-32-char-random-string"
JWT_EXPIRES_IN="7d"

# ─── Google OAuth (optional) ────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App URLs ────────────────────────────────────────────────────────
APP_URL="https://yourdomain.com"
VITE_API_URL=""
VITE_WS_URL=""

# ─── CORS ────────────────────────────────────────────────────────────
CORS_ORIGIN="https://yourdomain.com"

# ─── Storage (S3-compatible, optional) ──────────────────────────────
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# ─── Railway / Render ───────────────────────────────────────────────
PORT=3001
NODE_ENV=production
